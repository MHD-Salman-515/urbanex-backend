{
  "name": "urbanex-backend",
  "version": "0.0.1",
  "description": "Urbanex backend API",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start:prod": "node dist/main.js",
    "build": "tsc -p tsconfig.build.json",
    "build:render": "npm run build",
    "start": "nest start",
    "start:dev": "kill-port 3000 && nest start --watch",
    "start:dev:clean": "npm run port:free && nest start --watch",
    "start:dev:housing": "dotenv -e .env.housing -- nest start --watch",
    "start:dev:urbanex": "dotenv -e .env.urbanex -- nest start --watch",
    "start:debug": "nest start --debug --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:deploy:urbanex": "node scripts/prisma-migrate-urbanex.mjs",
    "migrate:urbanex": "dotenv -e .env.urbanex -- prisma migrate deploy",
    "port:free": "kill -9 $(lsof -ti:3000) 2>/dev/null || true",
    "ports:check": "sh -c 'for p in 3000 3001 3002 3003; do echo \"== Port $p ==\"; lsof -nP -iTCP:$p -sTCP:LISTEN || true; done'",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed:admin": "ts-node scripts/create-admin.ts",
    "seed:config": "ts-node scripts/seed-config-template.ts",
    "seed:generate": "ts-node scripts/generate-market-seed.ts",
    "seed:market": "ts-node scripts/seed-market-data.ts data/market-seed.csv",
    "market:import": "ts-node scripts/import-market-csv.ts",
    "start:clean": "npm run port:free && npm run start:dev",
    "props:seed": "node ../my-real-state-front-end/my-real-state/scripts/generate-and-import-properties.mjs",
    "demo:images:fetch": "node scripts/fetch-demo-images.mjs",
    "props:images:regen": "ts-node scripts/regen-property-images.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.7.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "canvas-confetti": "^1.9.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.35.0",
    "lucide-react": "^0.577.0",
    "multer": "^2.0.2",
    "mysql2": "^3.19.0",
    "openai": "^6.25.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.3",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.5.0",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-github2": "^1.2.8",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "kill-port": "^2.0.1",
    "prettier": "^3.4.2",
    "prisma": "^6.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^src/(.*)$": "rootDir/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
