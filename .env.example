#
# Runtime environment
# These variables are used by the NestJS app at boot time.
#

NODE_ENV=development
PORT=3000

# Comma-separated frontend origins. In production, set this to your Vercel app URL(s).
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Runtime databases
# Local example:
DATABASE_URL=mysql://root:@127.0.0.1:3306/housing_db
URBANEX_DATABASE_URL=mysql://root:@127.0.0.1:3306/urbanex_ai
# Production example:
# DATABASE_URL=mysql://avnadmin:password@host:27109/housing_db?ssl-mode=REQUIRED
# URBANEX_DATABASE_URL=mysql://avnadmin:password@host:27109/urbanex_ai?ssl-mode=REQUIRED

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
# Optional fallback secret for older code paths.
JWT_SECRET=
JWT_OTP_SECRET=
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800
OTP_TOKEN_TTL=900
OTP_REQUIRED=false
EMAIL_VERIFICATION_REQUIRED=false
AUTH_ALLOWED_ROLES=
PASSWORD_PEPPER=
AUTH_PEPPER=
BCRYPT_PEPPER=

# Mail / OTP
RESEND_API_KEY=
MAIL_FROM=onboarding@resend.dev

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_CALLBACK_BASE=http://localhost:3000
FRONTEND_OAUTH_REDIRECT=http://localhost:5174/auth/oauth/callback

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Startup behavior
RUN_DB_HOTFIX=false

#
# Script-only variables
# These are used by utility scripts that connect through mysql2 instead of Prisma.
#
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=housing_db
DEMO_IMAGES_PUBLIC_ROOT=
