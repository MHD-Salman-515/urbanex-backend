              "raw": "{\n  \"log_id\": \"12345\",\n  \"action\": \"accepted_optimal\",\n  \"final_price_syp\": 1798160000\n}"
            },
            "url": "{{baseUrl}}/advisor/track"
          }
        },
        {
          "name": "Advisor Analytics",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/advisor/analytics?days=7"
          }
        },
        {
          "name": "Insights",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/advisor/insights?city=damascus&district=mazzeh&property_type=apartment&days_window=90"
          }
        },
        {
          "name": "Simulate",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"city\": \"damascus\",\n  \"district\": \"mazzeh\",\n  \"property_type\": \"apartment\",\n  \"area_m2\": 150,\n  \"proposed_price_syp\": 1800000000,\n  \"days_window\": 90\n}"
            },
            "url": "{{baseUrl}}/advisor/simulate"
          }
        }
      ]
    },
    {
      "name": "4) Market Intelligence (snapshots/trends)",
      "item": [
        {
          "name": "Rebuild Snapshots (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"days\": 365\n}" },
            "url": "{{baseUrl}}/admin/market/rebuild-snapshots"
          }
        },
        {
          "name": "Market Trends",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/market/trends?city=damascus&district=mazzeh&property_type=apartment&days=30"
          }
        }
      ]
    },
    {
      "name": "5) External Market Baseline",
      "item": [
        {
          "name": "Create Source",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Syrian Listings Portal\",\n  \"source_type\": \"website\",\n  \"reliability_score\": 0.8\n}"
            },
            "url": "{{baseUrl}}/admin/external-market/sources"
          }
        },
        {
          "name": "List Sources",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": "{{baseUrl}}/admin/external-market/sources"
          }
        },
        {
          "name": "Create Observation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source_id\": 1,\n  \"city\": \"damascus\",\n  \"district\": \"mazzeh\",\n  \"property_type\": \"apartment\",\n  \"metric\": \"price_per_m2_syp\",\n  \"value\": 3500000,\n  \"value_unit\": \"SYP_PER_M2\",\n  \"published_at\": \"2026-03-01T12:00:00.000Z\",\n  \"url\": \"https://example.com/listing/123\"\n}"
            },
            "url": "{{baseUrl}}/admin/external-market/observations"
          }
        },
        {
          "name": "Import CSV (multipart)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" },
                { "key": "source_id", "value": "1", "type": "text" },
                { "key": "metric", "value": "price_per_m2_syp", "type": "text" },
                { "key": "value_unit", "value": "SYP_PER_M2", "type": "text" },
                { "key": "months_window", "value": "12", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/admin/external-market/import-csv"
          }
        },
        {
          "name": "Rebuild Baseline",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"months_window\": 12\n}" },
            "url": "{{baseUrl}}/admin/external-market/rebuild-baseline"
          }
        },
        {
          "name": "Get Baseline",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": "{{baseUrl}}/admin/external-market/baseline?city=damascus&district=mazzeh&propertyType=apartment"
          }
        }
      ]
    },
