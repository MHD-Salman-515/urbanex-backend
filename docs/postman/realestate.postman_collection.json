{
  "info": {
    "name": "RealEstate-System APIs (Owner + Buyer + Admin)",
    "description": "Comprehensive API collection for Auth, Owner Chat, Advisor, Market Intelligence, External Baseline, Buyer Chat, Saved Searches, Buyer History, Owner Portfolio Analyzer, and Admin Exports.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1) Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Postman Owner\",\n  \"email\": \"owner@example.com\",\n  \"phone\": \"+963999000111\",\n  \"password\": \"Pass1234!\",\n  \"role\": \"OWNER\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login (Auto set {{token}})",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let data = {};",
                  "try { data = pm.response.json(); } catch(e) {}",
                  "const token = data.access_token || data.token || data?.data?.access_token || data?.data?.token;",
                  "if (token) {",
                  "  pm.environment.set('token', token);",
                  "  pm.test('Token saved to environment', function () { pm.expect(token).to.be.a('string').and.not.empty; });",
                  "} else {",
                  "  pm.test('Token missing in login response', function () { pm.expect.fail('No access_token/token found'); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"Pass1234!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "2) Owner Chat",
      "item": [
        {
          "name": "Create Session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Owner Chat Session\"\n}" },
            "url": "{{baseUrl}}/owner/chat/sessions"
          }
        },
        {
          "name": "List Sessions",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": "{{baseUrl}}/owner/chat/sessions?limit=20"
          }
        },
        {
          "name": "List Session Messages",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": "{{baseUrl}}/owner/chat/sessions/{{ownerChatSessionId}}/messages?limit=50"
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"قيّم سعر عقاري\",\n  \"context\": { \"propertyId\": 1 }\n}"
            },
            "url": "{{baseUrl}}/owner/chat/sessions/{{ownerChatSessionId}}/message"
          }
        },
        {
          "name": "Apply Price Action",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": {{ownerChatSessionId}},\n  \"propertyId\": 1,\n  \"price\": 1800000000\n}"
            },
            "url": "{{baseUrl}}/owner/chat/actions/apply-price"
          }
        },
        {
          "name": "Update Session Context",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"property_id\": 1\n}" },
            "url": "{{baseUrl}}/owner/chat/sessions/{{ownerChatSessionId}}/context"
          }
        }
      ]
    },
    {
